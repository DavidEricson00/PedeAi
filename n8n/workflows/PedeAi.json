        "query": "UPDATE user_sessions\nSET \n  state = 'awaiting_order_menu_option',\n  data = jsonb_set(\n    COALESCE(data, '{}'::jsonb),\n    '{optionsMap}',\n    $2::jsonb,\n    true\n  )\nWHERE chat_id = $1;",
