    {
      "parameters": {
        "jsCode": "const categories = items.map(item => item.json);\n\nlet menu = \"🛒 Seu Pedido\\n\\n\";\nmenu += \"O que você gostaria de fazer agora?\\n\\n\";\nmenu += \"[ 1 ] - Finalizar Pedido\\n\";\n\nlet counter = 2;\n\nlet optionsMap = {\n  1: { type: \"finalizar\" }\n};\n\nfor (const category of categories) {\n  menu += `[ ${counter} ] - Adicionar ${category.name}\\n`;\n\n  optionsMap[counter] = {\n    type: \"categoria\",\n    categoryId: category.id,\n    name: category.name\n  };\n\n  counter++;\n}\n\nmenu += \"\\nDigite o número da opção desejada.\";\n\nconst globalData = $getWorkflowStaticData(\"global\");\nconst chatId = $node[\"Check State\"].json.chatId;\n\nglobalData[chatId] = {\n  state: \"waiting_category\",\n  optionsMap\n};\n\nreturn [\n  {\n    json: {\n      chatId,\n      menu\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1232,
        48
      ],
      "id": "246a9042-1754-43ae-b310-8b350b66bac0",
      "name": "Render Order Menu"
    },
    {
      "parameters": {
        "jsCode": "const globalData = $getWorkflowStaticData(\"global\");\n\nconst chatId = $json.chatId;\nconst number = Number($json.text);\nconst optionsMap = $json.optionsMap;\n\nconst option = optionsMap?.[number];\n\nif (!option) {\n\n  if (globalData[chatId]) {\n    globalData[chatId].state = \"main_menu\";\n  }\n\n  return [{\n    json: {\n      chatId,\n      type: \"invalid_option\",\n      menu: \"Opção inválida. Voltando ao menu principal.\"\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    chatId,\n    type: option.type,\n    categoryId: option.categoryId,\n    name: option.name\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
