      "parameters": {
        "jsCode": "const globalData = $getWorkflowStaticData(\"global\");\n\nconst chatId = $json.message.chat.id;\nconst text = $json.message.text;\n\nconst userData = globalData[chatId];\n\nreturn [\n  {\n    json: {\n      chatId,\n      text,\n      state: userData?.state || \"main_menu\",\n      optionsMap: userData?.optionsMap || null\n    }\n  }\n];"
      },
