    {
      "parameters": {
        "jsCode": "const products = items.map(item => item.json);\n\nconst chatId = $node[\"Check State\"].json.chatId;\nconst categoryName = $node[\"Process Category\"].json.name;\n\nlet menu = `📕 Cardápio de ${categoryName}\\n\\n`;\nmenu += \"[ 1 ] - Voltar\\n\";\n\nlet counter = 2;\n\nlet optionsMap = {\n  1: { type: \"back_to_menu\" }\n};\n\nfor (const product of products) {\n\n  if (!product.active) continue;\n\n  menu += `[ ${counter} ] - ${product.name} (R$ ${product.price})\\n`;\n\n  optionsMap[counter] = {\n    type: \"product\",\n    productId: product.id,\n    name: product.name,\n    price: product.price\n  };\n\n  counter++;\n}\n\nmenu += \"\\nDigite o número da opção desejada.\";\n\nconst globalData = $getWorkflowStaticData(\"global\");\n\nglobalData[chatId] = {\n  state: \"waiting_product\",\n  optionsMap\n};\n\nreturn [\n  {\n    json: {\n      chatId,\n      menu\n    }\n  }\n];"
      },
